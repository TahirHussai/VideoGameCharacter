@page "/characters"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using VideoGameCharacter.Application.Dtos
@using VideoGameCharacter.UI.Services
@inject CharacterApiClient ApiClient
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Characters</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-primary">Video Game Characters</h1>
        <button class="btn btn-success shadow-sm" @onclick="CreateNewCharacter">
            <i class="bi bi-plus-lg me-2"></i>Add Character
        </button>
    </div>

    @if (characters == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!characters.Any())
    {
        <div class="alert alert-info text-center shadow-sm" role="alert">
            <i class="bi bi-info-circle me-2"></i>No characters found. Add one to get started!
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Game</th>
                            <th>Role</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var character in characters)
                        {
                            <tr>
                                <td class="ps-4 align-middle fw-semibold">@character.Name</td>
                                <td class="align-middle">@character.Game</td>
                                <td class="align-middle">
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill">@character.Role</span>
                                </td>
                                <td class="text-end pe-4 align-middle">
                                    <button class="btn btn-outline-primary btn-sm me-2 rounded-3" @onclick="() => EditCharacter(character)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm rounded-3" @onclick="() => DeleteCharacter(character.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (showModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header bg-primary text-white border-0">
                        <h5 class="modal-title">@(isEditing ? "Edit Character" : "New Character")</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <EditForm Model="@editingCharacter" OnValidSubmit="SaveCharacter">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label fw-bold">Name</label>
                                <InputText @bind-Value="editingCharacter.Name" class="form-control" placeholder="Enter character name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Game</label>
                                <InputText @bind-Value="editingCharacter.Game" class="form-control" placeholder="Enter game title" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Role</label>
                                <InputText @bind-Value="editingCharacter.Role" class="form-control" placeholder="Enter role (e.g., Protagonist)" />
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button type="button" class="btn btn-light px-4" @onclick="CloseModal">Cancel</button>
                                <button type="submit" class="btn btn-primary px-4 shadow-sm">Save Changes</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<CharacterResponse>? characters;
    private bool showModal = false;
    private bool isEditing = false;
    private CharacterResponse editingCharacter = new();

    /// <summary>
    /// Lifecycle method called when the component is initialized.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadCharacters();
    }

    /// <summary>
    /// Loads the list of characters from the API.
    /// </summary>
    private async Task LoadCharacters()
    {
        var response = await ApiClient.GetAllCharactersAsync();
        if (response.IsSuccess)
        {
            characters = response.Data;
        }
        else
        {
            // Handle error (e.g., show a message)
            characters = new List<CharacterResponse>();
        }
    }

    private void CreateNewCharacter()
    {
        isEditing = false;
        editingCharacter = new();
        showModal = true;
    }

    private void EditCharacter(CharacterResponse character)
    {
        isEditing = true;
        editingCharacter = new CharacterResponse
        {
            Id = character.Id,
            Name = character.Name,
            Game = character.Game,
            Role = character.Role
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    /// <summary>
    /// Saves the current character (add or update) to the API.
    /// </summary>
    private async Task SaveCharacter()
    {
        ApiResponse<bool> response;
        if (isEditing)
        {
            var updateRequest = new UpdateCharacterRequest
            {
                Id = editingCharacter.Id,
                Name = editingCharacter.Name,
                Game = editingCharacter.Game,
                Role = editingCharacter.Role
            };
            response = await ApiClient.UpdateCharacterAsync(editingCharacter.Id, updateRequest);
        }
        else
        {
            var createRequest = new CreateCharacterRequest
            {
                Name = editingCharacter.Name,
                Game = editingCharacter.Game,
                Role = editingCharacter.Role
            };
            response = await ApiClient.AddCharacterAsync(createRequest);
        }

        if (response.IsSuccess)
        {
            showModal = false;
            await LoadCharacters();
        }
        else
        {
            // Potential: show error message in modal
        }
    }

    /// <summary>
    /// Deletes a character by its identifier.
    /// </summary>
    private async Task DeleteCharacter(int id)
    {
        var response = await ApiClient.DeleteCharacterAsync(id);
        if (response.IsSuccess)
        {
            await LoadCharacters();
        }
    }
}
