@page "/login"
@* Enable interactive server rendering to allow LocalStorage access, with prerendering disabled to prevent early JS Interop calls *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using VideoGameCharacter.Application.Dtos.Auth
@using VideoGameCharacter.UI.Services
@inject AuthApiService AuthApiService
@inject NavigationManager NavigationManager

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="font-weight-light my-4">Login</h3>
                </div>
                <div class="card-body">
                    @* FormName is required in .NET 8 Blazor for proper form submission mapping *@
                    <EditForm Model="loginRequest" OnValidSubmit="HandleLogin" FormName="LoginForm">
                        <DataAnnotationsValidator />
                        <div class="form-group mb-3">
                            <label class="small mb-1" for="username">Email</label>
                            <InputText id="username" class="form-control py-4" @bind-Value="loginRequest.Email" placeholder="Enter email address" />
                            <ValidationMessage For="() => loginRequest.Email" class="text-danger small" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="small mb-1" for="password">Password</label>
                            <InputText id="password" type="password" class="form-control py-4" @bind-Value="loginRequest.Password" placeholder="Enter password" />
                            <ValidationMessage For="() => loginRequest.Password" class="text-danger small" />
                        </div>
                        <div class="form-group d-flex align-items-center justify-content-between mt-4 mb-0">
                            <button class="btn btn-primary w-100" type="submit">Login</button>
                        </div>
                    </EditForm>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            @errorMessage
                        </div>
                    }
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a href="/register">Need an account? Sign up!</a></div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm] // Bind the form data to this model during submission
    private LoginRequest loginRequest { get; set; } = new() { Email = "", Password = "" };
    
    private string? errorMessage;

    /// <summary>
    /// Processes the login request via the Auth API service.
    /// </summary>
    private async Task HandleLogin()
    {
        errorMessage = null;
        var result = await AuthApiService.LoginAsync(loginRequest);
        
        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            errorMessage = result.Message;
        }
    }
}
